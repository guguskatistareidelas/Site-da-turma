# ── Digital Binder – Backend Environment Variables ──────────
# Copie este arquivo para .env e preencha com seus valores.

# Senha do admin (o líder de turma usa isso para desbloquear o modo admin)
ADMIN_PASSWORD=suasenha123

# String de conexão do MongoDB Atlas
# Exemplo: mongodb+srv://usuario:senha@cluster0.xxxxx.mongodb.net/
MONGODB_URI=mongodb+srv://usuario:senha@cluster0.xxxxx.mongodb.net/

# Cloudinary (armazenamento de arquivos)
CLOUDINARY_CLOUD_NAME=seu_cloud_name
CLOUDINARY_API_KEY=sua_api_key
CLOUDINARY_API_SECRET=seu_api_secret

# URL do frontend (para CORS em produção)
FRONTEND_URL=http://localhost:5173

# Porta do servidor (padrão: 4000)
PORT=4000
